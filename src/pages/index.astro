---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout title="bigbook — bilingual reader (work in progress)">
  <main>
    <h1>bigbook &mdash; bilingual reader</h1>
    <p>
      A bilingual side-by-side reader of the AA Big Book (English / Estonian) is under construction
      here. It will support GitHub-authenticated editing of the Estonian text, paragraph-level
      comments visible to logged-in visitors, and GitHub-versioned commits for every edit.
    </p>
    <p>
      In the meantime, the manually-transcribed Estonian-only Jekyll edition is preserved as a
      read-only archive at
      <a href="/bigbook/legacy/">/bigbook/legacy/</a>.
    </p>

    <section
      aria-label="Sign in"
      style="margin-top: 2rem; padding-top: 1rem; border-top: 1px solid #e5e7eb;"
    >
      <h2>GitHub sign-in (proof of concept)</h2>
      <div id="auth-status">Checking your session&hellip;</div>
      <button id="signin-btn" type="button" style="display: none">Sign in with GitHub</button>
      <div id="signedin-view" style="display: none; align-items: center; gap: 0.75rem">
        <img id="avatar" alt="avatar" width="32" height="32" style="border-radius: 50%" />
        <span>
          Signed in as
          <a id="profile-link" target="_blank" rel="noopener noreferrer"
            >@<span id="username"></span></a
          >
        </span>
        <button id="signout-btn" type="button">Sign out</button>
      </div>
    </section>
  </main>
  <script>
    import { beginAuth, currentUser, isSignedIn, signOut } from '../lib/auth/github-app'

    const authStatusEl = document.getElementById('auth-status')
    const signinBtn = document.getElementById('signin-btn') as HTMLButtonElement | null
    const signedinView = document.getElementById('signedin-view') as HTMLDivElement | null
    const avatarImg = document.getElementById('avatar') as HTMLImageElement | null
    const profileLink = document.getElementById('profile-link') as HTMLAnchorElement | null
    const usernameEl = document.getElementById('username')
    const signoutBtn = document.getElementById('signout-btn') as HTMLButtonElement | null

    function showSigninButton(): void {
      if (authStatusEl) {
        authStatusEl.style.display = 'none'
      }
      if (signinBtn) {
        signinBtn.style.display = 'inline-block'
      }
      if (signedinView) {
        signedinView.style.display = 'none'
      }
    }

    function showSignedInView(user: { login: string; avatar_url: string; html_url: string }): void {
      if (authStatusEl) {
        authStatusEl.style.display = 'none'
      }
      if (signinBtn) {
        signinBtn.style.display = 'none'
      }
      if (signedinView) {
        signedinView.style.display = 'flex'
      }
      if (avatarImg) {
        avatarImg.src = user.avatar_url
      }
      if (profileLink) {
        profileLink.href = user.html_url
      }
      if (usernameEl) {
        usernameEl.textContent = user.login
      }
    }

    signinBtn?.addEventListener('click', () => {
      beginAuth().catch((err: unknown) => {
        const message = err instanceof Error ? err.message : String(err)
        if (authStatusEl) {
          authStatusEl.style.display = 'block'
          authStatusEl.textContent = `Failed to begin sign-in: ${message}`
        }
      })
    })

    signoutBtn?.addEventListener('click', () => {
      signOut()
      showSigninButton()
    })

    async function init(): Promise<void> {
      if (!isSignedIn()) {
        showSigninButton()
        return
      }
      const user = await currentUser()
      if (user) {
        showSignedInView(user)
      } else {
        showSigninButton()
      }
    }

    init().catch((err: unknown) => {
      const message = err instanceof Error ? err.message : String(err)
      if (authStatusEl) {
        authStatusEl.textContent = `Auth init failed: ${message}`
      }
    })
  </script>
</BaseLayout>
