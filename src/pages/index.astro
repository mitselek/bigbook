---
import BaseLayout from '../layouts/BaseLayout.astro'
import TopBar from '../components/TopBar.astro'
import Footer from '../components/Footer.astro'
import ChapterSection from '../components/ChapterSection.svelte'
import { CHAPTERS } from '../lib/content/manifest'
---

<BaseLayout title="Big Book — Bilingual Reader">
  <TopBar>
    <div slot="auth" id="auth-widget">
      <button id="signin-btn" type="button" style="display: none; font-size: 12px;">Sisene</button>
      <div id="signedin-view" style="display: none; align-items: center; gap: 6px;">
        <img id="avatar" alt="" width="24" height="24" style="display: none; border-radius: 50%;" />
        <span id="login-text" style="display: none; font-size: 12px;"></span>
        <button id="signout-btn" type="button" style="font-size: 12px;">Lahku</button>
      </div>
    </div>
  </TopBar>

  <main class="reader-body">
    {
      CHAPTERS.map((chapter) => (
        <ChapterSection
          client:idle
          slug={chapter.slug}
          paraIds={chapter.paraIds}
          titleEn={chapter.title.en}
          titleEt={chapter.title.et}
        />
      ))
    }
  </main>

  <Footer />

  <script>
    import { beginAuth, currentUser, isSignedIn, signOut } from '../lib/auth/github-app'
    import { createTitleObserver } from '../lib/reader/scroll-anchor'
    import { readerState, initializeChapterStates } from '../lib/reader/store.svelte'
    import { getLastParaId } from '../lib/reader/local-state'
    import { CHAPTERS } from '../lib/content/manifest'

    // Auth
    const signinBtn = document.getElementById('signin-btn') as HTMLButtonElement | null
    const signedinView = document.getElementById('signedin-view') as HTMLDivElement | null
    const avatarImg = document.getElementById('avatar') as HTMLImageElement | null
    const loginText = document.getElementById('login-text') as HTMLSpanElement | null
    const signoutBtn = document.getElementById('signout-btn') as HTMLButtonElement | null

    function showSigninButton(): void {
      if (signinBtn) signinBtn.style.display = 'inline-block'
      if (signedinView) signedinView.style.display = 'none'
      if (avatarImg) avatarImg.style.display = 'none'
      if (loginText) loginText.style.display = 'none'
    }

    function showSignedInView(user: { avatar_url: string; login: string }): void {
      if (signinBtn) signinBtn.style.display = 'none'
      if (signedinView) signedinView.style.display = 'flex'
      if (user.avatar_url) {
        if (avatarImg) {
          avatarImg.src = user.avatar_url
          avatarImg.style.display = 'inline-block'
        }
        if (loginText) loginText.style.display = 'none'
      } else {
        if (avatarImg) avatarImg.style.display = 'none'
        if (loginText) {
          loginText.textContent = user.login
          loginText.style.display = 'inline'
        }
      }
    }

    signinBtn?.addEventListener('click', () => {
      beginAuth().catch(() => {})
    })

    signoutBtn?.addEventListener('click', () => {
      signOut()
      showSigninButton()
      readerState.isAuthenticated = false
    })

    async function initAuth(): Promise<void> {
      if (!isSignedIn()) {
        showSigninButton()
        return
      }
      const user = await currentUser()
      if (user) showSignedInView(user)
      else showSigninButton()
    }

    initAuth()
      .then(() => {
        readerState.isAuthenticated = isSignedIn()
      })
      .catch(() => {})

    // Initialize reader state
    initializeChapterStates(CHAPTERS.map((c) => c.slug))

    // Title observer — update top bar title as chapters scroll
    const titleObserver = createTitleObserver((slug) => {
      readerState.currentChapter = slug
    })

    requestAnimationFrame(() => {
      document.querySelectorAll('[data-chapter-slug]').forEach((el) => {
        const slug = (el as HTMLElement).dataset.chapterSlug
        if (slug) titleObserver.observe(el as HTMLElement, slug)
      })
    })

    // Return-visit scroll
    const lastParaId = getLastParaId()
    if (lastParaId) {
      const target = document.getElementById(lastParaId)
      if (target) {
        requestAnimationFrame(() => {
          const rect = target.getBoundingClientRect()
          const top = window.scrollY + rect.top - window.innerHeight / 3
          window.scrollTo({ top, behavior: 'instant' })
        })
      }
    }

    // Keyboard navigation: ← / → to move between chapters
    const slugs = CHAPTERS.map((c) => c.slug)

    // Keyboard shortcut: / to open TOC
    document.addEventListener('keydown', (e) => {
      const target = e.target as HTMLElement
      const inEditable =
        target.tagName === 'INPUT' || target.tagName === 'TEXTAREA' || target.isContentEditable

      if (e.key === '/' && !e.ctrlKey && !e.metaKey) {
        if (inEditable) return
        e.preventDefault()
        // TOC toggle is handled via custom event
        document.dispatchEvent(new CustomEvent('bigbook:toggle-toc'))
      }

      if (e.key === 'ArrowLeft' || e.key === 'ArrowRight') {
        if (e.ctrlKey || e.metaKey || e.altKey || e.shiftKey) return
        if (inEditable) return
        const idx = slugs.indexOf(readerState.currentChapter)
        if (e.key === 'ArrowLeft' && idx > 0) {
          e.preventDefault()
          document
            .getElementById(`chapter-${slugs[idx - 1]}`)
            ?.scrollIntoView({ behavior: 'smooth', block: 'start' })
        } else if (e.key === 'ArrowRight' && idx >= 0 && idx < slugs.length - 1) {
          e.preventDefault()
          document
            .getElementById(`chapter-${slugs[idx + 1]}`)
            ?.scrollIntoView({ behavior: 'smooth', block: 'start' })
        }
      }
    })

    // Visibility-change refresh — dispatches custom event, ChapterSections listen
    let lastHiddenAt = 0
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        lastHiddenAt = Date.now()
        return
      }
      const hiddenMs = Date.now() - lastHiddenAt
      if (hiddenMs < 120_000) return
      document.dispatchEvent(new CustomEvent('bigbook:refresh-chapters'))
    })
  </script>
</BaseLayout>

<style>
  .reader-body {
    background: #faf8f5;
    font-family: Georgia, 'Times New Roman', serif;
    padding: 0;
  }
</style>
