{
  "name": "bigbook",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Bilingual side-by-side reader for the AA Big Book (EN/ET) with GitHub-authenticated editing.",
  "license": "MIT",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "size": "size-limit",
    "e2e": "playwright test --project=chromium",
    "e2e:all-browsers": "playwright test",
    "bootstrap:content": "CONTENT_BOOTSTRAP=1 tsx scripts/bootstrap-mock-content.ts"
  },
  "dependencies": {
    "astro": "^5.0.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.89.0",
    "@astrojs/check": "^0.9.0",
    "@astrojs/svelte": "^7.2.5",
    "@playwright/test": "^1.59.1",
    "@size-limit/preset-app": "^11.2.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.0.0",
    "eslint-plugin-astro": "^1.3.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-svelte": "^2.46.1",
    "jsdom": "^25.0.1",
    "lefthook": "^1.7.0",
    "prettier": "^3.3.0",
    "prettier-plugin-astro": "^0.14.0",
    "prettier-plugin-svelte": "^3.5.1",
    "size-limit": "^11.2.0",
    "svelte": "^5.55.4",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.1.0"
  }
}
