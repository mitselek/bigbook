---
import BaseLayout from '../layouts/BaseLayout.astro'
import TopBar from '../components/TopBar.astro'
import Footer from '../components/Footer.astro'
import { CHAPTERS, ESTIMATED_HEIGHT_TITLE, ESTIMATED_HEIGHT_BODY } from '../lib/content/manifest'
---

<BaseLayout title="Big Book — Bilingual Reader">
  <TopBar>
    <div slot="auth" id="auth-widget">
      <button id="signin-btn" type="button" style="display: none; font-size: 12px;">
        Sign in
      </button>
      <div id="signedin-view" style="display: none; align-items: center; gap: 6px;">
        <img id="avatar" alt="avatar" width="24" height="24" style="border-radius: 50%;" />
        <button id="signout-btn" type="button" style="font-size: 12px;">Sign out</button>
      </div>
    </div>
  </TopBar>

  <main class="reader-body">
    {
      CHAPTERS.map((chapter) => (
        <section
          class="chapter-section"
          id={`chapter-${chapter.slug}`}
          data-chapter-slug={chapter.slug}
        >
          {chapter.paraIds.map((paraId) => (
            <div
              class={`skeleton-row ${paraId.endsWith('-title') ? 'skeleton-title' : 'skeleton-body'}`}
              id={paraId}
              style={`min-height: ${paraId.endsWith('-title') ? ESTIMATED_HEIGHT_TITLE : ESTIMATED_HEIGHT_BODY}px`}
            >
              <div class="skeleton-en" />
              <div class="skeleton-et" />
              <div class="skeleton-marginalia" />
            </div>
          ))}
        </section>
      ))
    }
  </main>

  <Footer />

  <script>
    import { beginAuth, currentUser, isSignedIn, signOut } from '../lib/auth/github-app'

    const signinBtn = document.getElementById('signin-btn') as HTMLButtonElement | null
    const signedinView = document.getElementById('signedin-view') as HTMLDivElement | null
    const avatarImg = document.getElementById('avatar') as HTMLImageElement | null
    const signoutBtn = document.getElementById('signout-btn') as HTMLButtonElement | null

    function showSigninButton(): void {
      if (signinBtn) {
        signinBtn.style.display = 'inline-block'
      }
      if (signedinView) {
        signedinView.style.display = 'none'
      }
    }

    function showSignedInView(user: { avatar_url: string }): void {
      if (signinBtn) {
        signinBtn.style.display = 'none'
      }
      if (signedinView) {
        signedinView.style.display = 'flex'
      }
      if (avatarImg) {
        avatarImg.src = user.avatar_url
      }
    }

    signinBtn?.addEventListener('click', () => {
      beginAuth().catch(() => {})
    })

    signoutBtn?.addEventListener('click', () => {
      signOut()
      showSigninButton()
    })

    async function init(): Promise<void> {
      if (!isSignedIn()) {
        showSigninButton()
        return
      }
      const user = await currentUser()
      if (user) {
        showSignedInView(user)
      } else {
        showSigninButton()
      }
    }

    init().catch(() => {})
  </script>
</BaseLayout>

<style>
  .reader-body {
    background: #faf8f5;
    font-family: Georgia, 'Times New Roman', serif;
    padding: 0;
  }
  .skeleton-row {
    display: flex;
    border-bottom: 1px solid #eae7e2;
    padding: 12px 20px;
  }
  .skeleton-title {
    padding: 16px 20px;
  }
  .skeleton-en {
    width: calc((100% - 140px) * 0.45);
    padding-right: 16px;
    border-right: 1px solid #e0ddd8;
  }
  .skeleton-et {
    width: calc((100% - 140px) * 0.55);
    padding-left: 16px;
  }
  .skeleton-marginalia {
    width: 140px;
    padding-left: 12px;
  }
</style>
